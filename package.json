{
  "name": "ossinsight-cli",
  "version": "1.0.0",
  "description": "CLI tool for querying OSSInsight API - outputs LLM-friendly text for open source intelligence",
  "type": "module",
  "bin": {
    "ossinsight": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
